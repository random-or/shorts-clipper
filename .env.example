# Shorts Clipper Environment Configuration
# Copy this file to .env and fill in your values.
# See README.md for full documentation of each variable.

# ---------------------------------------------------------
# Required
# ---------------------------------------------------------
# Google Gemini API key (metadata generation + semantic validation)
GEMINI_API_KEY=

# ---------------------------------------------------------
# Publishing — YouTube (OAuth2)
# ---------------------------------------------------------
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=

# Optional: YouTube Data API key (helps Scout avoid yt-dlp rate limits)
# YOUTUBE_API_KEY=

# ---------------------------------------------------------
# Publishing — Instagram (Graph API)
# ---------------------------------------------------------
IG_ACCESS_TOKEN=
IG_ACCOUNT_ID=

# Public URL where the web server is reachable (required for Instagram
# unless SHORTS_USE_TEMP_HOSTS is enabled)
# PUBLIC_URL=https://your-domain.com

# Set to true to use temporary file hosting instead of PUBLIC_URL
# SHORTS_USE_TEMP_HOSTS=false

# ---------------------------------------------------------
# GPU / Hardware Acceleration
# ---------------------------------------------------------
# SHORTS_ENABLE_GPU=false
# SHORTS_WHISPER_MODEL=tiny.en
# SHORTS_WHISPER_DEVICE=cpu
# SHORTS_WHISPER_COMPUTE_TYPE=int8
# SHORTS_VIDEO_CODEC=libx264
# SHORTS_VIDEO_PRESET=ultrafast

# ---------------------------------------------------------
# Pipeline Settings
# ---------------------------------------------------------
# SHORTS_SCOUT_MAX_AGE_DAYS=90
# SHORTS_SUBTITLE_STYLE=default
# SHORTS_PUBLISH_PLATFORMS=youtube,instagram
# SHORTS_PROVIDER=gemini
# SHORTS_LOG_LEVEL=INFO
# SHORTS_OUTPUT_DIR=outputs
# SHORTS_CACHE_DIR=.cache/shorts-clipper
# SHORTS_MODELS_DIR=models
# SHORTS_PROXY=
