# Shorts Clipper Environment Configuration
# Copy this file to .env and fill in the values.

# ---------------------------------------------------------
# AI & ML Providers
# ---------------------------------------------------------
# Your Google Gemini API Key (Required for SEO and Semantic Validation)
GEMINI_API_KEY=

# ---------------------------------------------------------
# YouTube Credentials
# ---------------------------------------------------------
# Required for publishing to YouTube Shorts
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=

# ---------------------------------------------------------
# Instagram Credentials
# ---------------------------------------------------------
# Required for publishing to Instagram Reels. 
# You can use username/password OR a valid session ID.
INSTAGRAM_USERNAME=
INSTAGRAM_PASSWORD=
INSTAGRAM_SESSION_ID=

# ---------------------------------------------------------
# Application Settings
# ---------------------------------------------------------
# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Number of concurrent workers for background jobs
WORKER_CONCURRENCY=2

# Maximum duration (in seconds) of input video to process (Default 3600 = 1 hour)
MAX_VIDEO_LENGTH=3600
