# AI providers
GEMINI_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434
SHORTS_PROVIDER=gemini

# Transcription
# Model options: tiny.en (fastest), base.en, small.en, medium.en, large-v3 (best)
# large-v3 is the default for production quality; use tiny.en for quick tests
SHORTS_WHISPER_MODEL=large-v3
SHORTS_WHISPER_DEVICE=cpu
# int8 for CPU (fastest), float16 for CUDA GPU
SHORTS_WHISPER_COMPUTE_TYPE=int8
SHORTS_MODELS_DIR=models

# Runtime paths
SHORTS_OUTPUT_DIR=outputs
SHORTS_CACHE_DIR=.cache/shorts-clipper
SHORTS_LOG_LEVEL=INFO
SHORTS_ENABLE_GPU=false
