# ──────────────────────────────────────────────────────────────
# Shorts Clipper — Environment Configuration
# ──────────────────────────────────────────────────────────────
# Copy this file:  cp .env.example .env
# Then fill in your API key below.

# ── AI Provider ──────────────────────────────────────────────
# Get a free Gemini API key at https://aistudio.google.com/
GEMINI_API_KEY=

# ── Transcription (Whisper) ──────────────────────────────────
# Model: tiny.en (fastest) | base.en | small.en | medium.en | large-v3 (best)
SHORTS_WHISPER_MODEL=tiny.en
SHORTS_WHISPER_DEVICE=cpu
# int8 for CPU (fastest), float16 for CUDA GPU
SHORTS_WHISPER_COMPUTE_TYPE=int8

# ── Video Encoding ───────────────────────────────────────────
SHORTS_VIDEO_CODEC=libx264
SHORTS_VIDEO_PRESET=ultrafast

# ── Scout Settings ───────────────────────────────────────────
SHORTS_SCOUT_MAX_AGE_DAYS=90

# ── GPU Acceleration ─────────────────────────────────────────
# Set to true to use h264_nvenc and CUDA Whisper
SHORTS_ENABLE_GPU=false

# ── Paths ────────────────────────────────────────────────────
SHORTS_OUTPUT_DIR=outputs
SHORTS_LOG_LEVEL=INFO
